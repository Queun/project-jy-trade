NODE_ENV="production"
API_PORT="3001"
# Controls the server-side scheduler only. The 1/2/6/24-hour interval is
# selected in Settings and stored in the database.
TZ="Asia/Shanghai"
WDT_AUTO_SYNC_ENABLED="true"

# This deployment uses a new runtime directory. Keeping paths absolute makes
# it impossible to confuse the new production database with the old test data.
DATABASE_URL="file:/opt/jy-trade/current/data/production/jy-trade-prod.db"
JY_TRADE_UPLOAD_DIR="/opt/jy-trade/current/data/production/uploads"
JY_TRADE_EXPORTS_DIR="/opt/jy-trade/current/data/production/exports"

# Trial admin account. Access is restricted by the Tencent Cloud IP allowlist.
# Its password is synchronized at every API startup, including an existing
# admin account. Keep this value aligned with the agreed trial password.
JY_TRADE_BOOTSTRAP_USERNAME="admin"
JY_TRADE_BOOTSTRAP_PASSWORD="yjmy"

# WDT read-only API credentials used by product and inventory snapshot sync.
WDT_ENV="prod"
WDT_PROD_API_BASE="http://wdt.wangdian.cn/openapi"
WDT_PROD_SID="..."
WDT_PROD_APPKEY="..."
WDT_PROD_APPSECRET="secret:salt"

# The initial product sync range for a newly created database. Later runs are
# incremental and overlap the previous run by one day.
WDT_GOODS_SYNC_START_DATE="2026-06-01"

# The following values already match application defaults. Leave them commented
# unless WDT rate limiting or a larger initial goods sync requires tuning.
# WDT_GOODS_SYNC_PAGE_SIZE="500"
# WDT_GOODS_SYNC_OVERLAP_DAYS="1"
# WDT_GOODS_SYNC_MAX_RETRIES="3"
# WDT_GOODS_SYNC_RETRY_DELAYS_MS="1000,3000,8000"
# WDT_STOCK_SYNC_RETRY_DELAYS_MS="1500"

# WDT_PROD_WAREHOUSE_NO="001"
# Legacy value used only by old diagnostic probes. The running service reads
# enabled warehouses from Settings, so do not configure warehouse selection here.
