NODE_ENV="production"
API_PORT="3001"
TZ="Asia/Shanghai"
WDT_AUTO_SYNC_ENABLED="true"

# Production database. Keep this path under the ignored runtime data directory.
DATABASE_URL="file:data/jy-trade-prod.db"

# Runtime file directories. Use absolute paths on servers if preferred.
JY_TRADE_UPLOAD_DIR="data/uploads"
JY_TRADE_EXPORTS_DIR="data/exports"

# Production admin account. Its password is synchronized at API startup.
JY_TRADE_BOOTSTRAP_USERNAME="admin"
JY_TRADE_BOOTSTRAP_PASSWORD="replace-with-a-strong-password"

# Use production WDT credentials for real read-only review.
WDT_ENV="prod"
WDT_PROD_API_BASE="http://wdt.wangdian.cn/openapi"
WDT_PROD_SID="..."
WDT_PROD_APPKEY="..."
WDT_PROD_APPSECRET="secret:salt"
WDT_PROD_WAREHOUSE_NO="001"

# Goods cache sync window and retry policy.
WDT_GOODS_SYNC_START_DATE="2026-06-01"
WDT_GOODS_SYNC_PAGE_SIZE="500"
WDT_GOODS_SYNC_OVERLAP_DAYS="1"
WDT_GOODS_SYNC_MAX_RETRIES="3"
WDT_GOODS_SYNC_RETRY_DELAYS_MS="1000,3000,8000"

# Stock snapshot retry delays after frequency or concurrency errors.
WDT_STOCK_SYNC_RETRY_DELAYS_MS="1500"
