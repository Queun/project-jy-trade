{
  "name": "project-jy-trade",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @jy-trade/api",
    "dev:web": "npm run dev -w @jy-trade/web",
    "start:api": "npm run start -w @jy-trade/api",
    "build:web": "npm run build -w @jy-trade/web",
    "release:check": "node tools/check-release.mjs",
    "deploy:check": "npm run release:check && npm run typecheck && npm run test -w @jy-trade/api && npm run test -w @jy-trade/web && npm run build:web",
    "build": "npm run build --workspaces --if-present",
    "db:generate": "npm run db:generate -w @jy-trade/api",
    "db:migrate": "npm run db:migrate -w @jy-trade/api",
    "test": "npm run test:workspaces && npm run test:backend",
    "test:workspaces": "npm run test --workspaces --if-present",
    "test:backend": "vitest run backend/src/flows/diagnoseOrder.test.ts",
    "test:e2e": "npm run test:e2e -w @jy-trade/web",
    "node:order": "tsx backend/src/probes/order-import.ts",
    "node:review": "tsx backend/src/probes/review-allocation.ts",
    "node:make-test-order": "tsx backend/src/probes/make-test-api-order.ts",
    "node:simulate": "tsx backend/src/probes/simulate-flow.ts",
    "node:trial-acceptance": "npm run trial-acceptance -w @jy-trade/api --",
    "node:wdt:contract": "tsx backend/src/probes/wdt-contract.ts",
    "node:wdt:sync-goods": "tsx backend/src/probes/sync-wdt-goods.ts",
    "node:diagnose-order": "tsx backend/src/probes/diagnose-order.ts",
    "node:confirm-mapping": "tsx backend/src/probes/confirm-product-mapping.ts",
    "node:wdt": "tsx backend/src/probes/wdt-api.ts",
    "typecheck": "tsc --noEmit && npm run typecheck --workspaces --if-present"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-table": "^8.21.3",
    "@vitejs/plugin-react": "^5.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.9.0",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.6",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.9",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^24.1.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
